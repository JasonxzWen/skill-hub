{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["bun-types", "node"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
